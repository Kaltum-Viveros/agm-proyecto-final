  "info": {
    "_postman_id": "47a0e716-d57a-4c17-917c-eb4e5ab08cf5",
    "name": "AGM Microservicios Locales",
    "description": "Colección local para probar microservicios AGM. Agrupada por microservicio, sin emojis, usando variables de entorno y guardado automático de IDs/tokens.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Utilidades",
      "item": [
        {
          "name": "Preparar datos dinámicos",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url_auth}}/health",
              "host": [
                "{{base_url_auth}}/health"
              ]
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "function uuidv4() {",
                  "  return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {",
                  "    const r = Math.random() * 16 | 0;",
                  "    const v = c === 'x' ? r : (r & 0x3 | 0x8);",
                  "    return v.toString(16);",
                  "  });",
                  "}",
                  "const suffix = Date.now().toString();",
                  "const shortSuffix = suffix.slice(-10);",
                  "pm.environment.set('test_suffix', shortSuffix);",
                  "pm.environment.set('docente_nombre', 'Docente Prueba ' + shortSuffix);",
                  "pm.environment.set('docente_correo', 'docente.prueba.' + shortSuffix + '@buap.mx');",
                  "pm.environment.set('docente_cubiculo', 'CCO-' + shortSuffix.slice(-3));",
                  "pm.environment.set('docente_horario_atencion', 'Lunes 10:00-12:00');",
                  "pm.environment.set('alumno_nombre', 'Alumno Prueba ' + shortSuffix);",
                  "pm.environment.set('alumno_correo', 'alumno.prueba.' + shortSuffix + '@alumno.buap.mx');",
                  "pm.environment.set('alumno_matricula', '2023' + shortSuffix.slice(-6));",
                  "pm.environment.set('alumno_tipo_formacion', 'Licenciatura');",
                  "pm.environment.set('materia_id', uuidv4());",
                  "pm.environment.set('periodo_id', uuidv4());",
                  "pm.environment.set('nrc_materia', 'NRC' + shortSuffix.slice(-5));",
                  "pm.environment.set('seccion_materia', '001');",
                  "console.log('Datos dinámicos preparados con suffix:', shortSuffix);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Datos dinámicos guardados', function () {",
                  "  pm.expect(pm.environment.get('docente_correo')).to.include('@buap.mx');",
                  "  pm.expect(pm.environment.get('alumno_matricula')).to.be.a('string');",
                  "});"
                ]
              }
            }
          ],
          "description": "Genera correos, matrícula, NRC, materia_id y periodo_id para pruebas limpias."
        }
      ]
    },
