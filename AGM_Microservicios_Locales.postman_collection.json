        {
          "name": "Importar docentes desde PDF",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "{{base_url_docentes_alumnos}}/api/v1/importar/docentes",
              "host": [
                "{{base_url_docentes_alumnos}}"
              ],
              "path": [
                "api",
                "v1",
                "importar",
                "docentes"
              ]
            },
            "description": "Selecciona manualmente un PDF. Este endpoint crea docentes desde PDF; según el código actual, genera user_id local con UUID, no necesariamente identidad en Auth."
          },
          "event": [
            {
              "listen": "test",
              "script": {
