          "name": "00.1 Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{ms_docentes_alumnos_base_url}}/",
            "description": "Verifica que MS-3 esté levantado. Se mantiene porque los health checks van al inicio de cada microservicio."
          },
