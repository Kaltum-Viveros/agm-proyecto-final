    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "function getVar(name) { return pm.environment.get(name) || pm.collectionVariables.get(name); }",
          "function setVar(name, value) {",
          "  if (value === undefined || value === null || value === '') return;",
          "  try { pm.environment.set(name, String(value)); } catch (e) {}",
          "  pm.collectionVariables.set(name, String(value));",
          "}",
          "function setIfMissing(name, value) { if (!getVar(name)) setVar(name, value); }",
          "function uuidv4() {",
          "  return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {",
          "    const r = Math.random() * 16 | 0;",
          "    const v = c === 'x' ? r : (r & 0x3 | 0x8);",
          "    return v.toString(16);",
          "  });",
          "}",
          "function todayIso() { return new Date().toISOString().slice(0, 10); }",
          "setIfMissing('ms_calificaciones_base_url', 'http://localhost:8004');",
          "const materiaAlias = getVar('materia_ofertada_id') || getVar('ms2_materia_ofertada_id');",
          "if (!getVar('materia_id') && materiaAlias) setVar('materia_id', materiaAlias);",
          "setIfMissing('materia_id', uuidv4());",
          "setIfMissing('alumno_id', uuidv4());",
          "setIfMissing('actividad_fecha', todayIso());",
          "setIfMissing('calificacion_valor', '8.50');",
