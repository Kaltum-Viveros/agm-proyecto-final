{
  "info": {
    "_postman_id": "4d3756cb-74d2-49c5-ba04-0c67ef635738",
    "name": "AGM - MS-4 Calificaciones & Ponderaciones - Pruebas reales",
    "description": "Colección de pruebas reales para MS-4 Calificaciones & Ponderaciones. Incluye health, ponderaciones, actividades, calificaciones, importación Excel/CSV y concentrado. Requiere access_token de un usuario DOCENTE válido para operaciones protegidas con RBAC/gRPC.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "function uuidv4() {",
          "  return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {",
          "    const r = Math.random() * 16 | 0;",
          "    const v = c === 'x' ? r : (r & 0x3 | 0x8);",
          "    return v.toString(16);",
          "  });",
          "}",
          "",
          "function getVar(name) {",
          "  return pm.environment.get(name) || pm.collectionVariables.get(name);",
          "}",
          "",
          "function setVar(name, value) {",
          "  if (value === undefined || value === null || value === '') return;",
          "  try { pm.environment.set(name, String(value)); } catch (e) {}",
          "  pm.collectionVariables.set(name, String(value));",
          "}",
          "",
          "function setIfMissing(name, value) {",
          "  if (!getVar(name)) setVar(name, value);",
          "}",
          "",
          "function todayIso() {",
          "  return new Date().toISOString().slice(0, 10);",
          "}",
          "",
          "setIfMissing('ms_calificaciones_base_url', 'http://localhost:8004');",
          "",
          "// Para MS-4, materia_id normalmente debe ser el id de la materia ofertada creado en MS-2.",
          "// Si ya existe materia_ofertada_id en el environment de MS-2/MS-3, se usa como materia_id.",
          "const materiaAlias = getVar('materia_ofertada_id') || getVar('ms2_materia_ofertada_id');",
          "if (!getVar('materia_id') && materiaAlias) setVar('materia_id', materiaAlias);",
          "setIfMissing('materia_id', uuidv4());",
          "",
          "// alumno_id debe venir idealmente de MS-3 y estar inscrito en materia_id para que calificaciones pase la validación gRPC.",
          "setIfMissing('alumno_id', uuidv4());",
          "setIfMissing('actividad_fecha', todayIso());",
          "setIfMissing('calificacion_valor', '8.50');",
          "setIfMissing('calificacion_valor_actualizada', '9.20');",
          "setIfMissing('calificacion_observaciones', 'Registro de prueba Postman');",
          "setIfMissing('calificacion_observaciones_actualizada', 'Actualización de prueba Postman');"
        ]
      }
    }
  ],
