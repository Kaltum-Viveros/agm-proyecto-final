      "name": "01 - Ponderaciones",
      "description": "Configura los criterios de evaluación de una materia. Ejecutar antes de crear actividades.",
      "item": [
        {
          "name": "Crear ponderaciones 100%",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{ms_calificaciones_base_url}}/api/v1/ponderaciones/{{materia_id}}",
              "host": [
                "{{ms_calificaciones_base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "ponderaciones",
                "{{materia_id}}"
              ]
            },
            "description": "Crea o reemplaza las ponderaciones de la materia. La suma debe ser exactamente 100%.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"criterios\": [\n    {\n      \"nombre\": \"Exámenes\",\n      \"porcentaje\": 40,\n      \"orden\": 1\n    },\n    {\n      \"nombre\": \"Tareas\",\n      \"porcentaje\": 30,\n      \"orden\": 2\n    },\n    {\n      \"nombre\": \"Proyecto\",\n      \"porcentaje\": 20,\n      \"orden\": 3\n    },\n    {\n      \"nombre\": \"Asistencia\",\n      \"porcentaje\": 10,\n      \"orden\": 4\n    }\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "function uuidv4() {",
                  "  return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {",
                  "    const r = Math.random() * 16 | 0;",
                  "    const v = c === 'x' ? r : (r & 0x3 | 0x8);",
                  "    return v.toString(16);",
                  "  });",
                  "}",
                  "function getVar(name) { return pm.environment.get(name) || pm.collectionVariables.get(name); }",
                  "function setVar(name, value) {",
                  "  if (value === undefined || value === null || value === '') return;",
                  "  try { pm.environment.set(name, String(value)); } catch (e) {}",
                  "  pm.collectionVariables.set(name, String(value));",
                  "}",
                  "function todayIso() { return new Date().toISOString().slice(0, 10); }",
                  "",
                  "const materiaAlias = getVar('materia_ofertada_id') || getVar('ms2_materia_ofertada_id');",
                  "if (materiaAlias) setVar('materia_id', materiaAlias);",
                  "if (!getVar('materia_id')) setVar('materia_id', uuidv4());",
                  "if (!getVar('alumno_id')) setVar('alumno_id', uuidv4());",
                  "setVar('actividad_fecha', todayIso());",
                  "setVar('calificacion_valor', '8.50');",
                  "setVar('calificacion_valor_actualizada', '9.20');",
                  "setVar('calificacion_observaciones', 'Registro de prueba Postman');",
                  "setVar('calificacion_observaciones_actualizada', 'Actualización de prueba Postman');",
                  "",
                  "// Limpia IDs propios de MS-4 para que se capturen los recursos recién creados.",
                  "[",
                  "  'ponderacion_examen_id',",
                  "  'ponderacion_tareas_id',",
                  "  'ponderacion_proyecto_id',",
                  "  'ponderacion_asistencia_id',",
                  "  'actividad_id',",
                  "  'calificacion_id'",
                  "].forEach(function (name) {",
                  "  try { pm.environment.unset(name); } catch (e) {}",
                  "  pm.collectionVariables.unset(name);",
                  "});"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 2xx', function () { pm.expect(pm.response.code).to.be.within(200, 299); });",
                  "function setVar(name, value) {",
                  "  if (value === undefined || value === null || value === '') return;",
                  "  try { pm.environment.set(name, String(value)); } catch (e) {}",
                  "  pm.collectionVariables.set(name, String(value));",
                  "}",
                  "let json = {};",
                  "try { json = pm.response.json(); } catch (e) { json = {}; }",
                  "const data = json.data || {};",
                  "setVar('materia_id', data.materia_id);",
                  "const criterios = data.criterios || [];",
                  "criterios.forEach(function (c) {",
                  "  const name = (c.nombre || '').toLowerCase();",
                  "  if (name.includes('examen') || name.includes('exámen')) setVar('ponderacion_examen_id', c.id);",
                  "  if (name.includes('tarea')) setVar('ponderacion_tareas_id', c.id);",
                  "  if (name.includes('proyecto')) setVar('ponderacion_proyecto_id', c.id);",
                  "  if (name.includes('asistencia')) setVar('ponderacion_asistencia_id', c.id);",
                  "});",
                  "if (criterios.length && !pm.variables.get('ponderacion_examen_id')) setVar('ponderacion_examen_id', criterios[0].id);"
                ]
              }
            }
          ]
        },
