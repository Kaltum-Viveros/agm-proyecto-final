    {
      "name": "01 - Ponderaciones",
      "description": "Flujo real: el docente configura criterios de evaluación por materia, con suma exacta de 100%.",
      "item": [
        {
          "name": "01.1 Crear ponderaciones 100%",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{ms_calificaciones_base_url}}/api/v1/ponderaciones/{{materia_id}}",
            "description": "Crea las ponderaciones iniciales de la materia. Deben sumar 100%. Ejecuta esta solicitud antes de crear actividades.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"criterios\": [\n    {\n      \"nombre\": \"Exámenes\",\n      \"porcentaje\": 40,\n      \"orden\": 1\n    },\n    {\n      \"nombre\": \"Tareas\",\n      \"porcentaje\": 30,\n      \"orden\": 2\n    },\n    {\n      \"nombre\": \"Proyecto\",\n      \"porcentaje\": 20,\n      \"orden\": 3\n    },\n    {\n      \"nombre\": \"Asistencia\",\n      \"porcentaje\": 10,\n      \"orden\": 4\n    }\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "function getVar(name) { return pm.environment.get(name) || pm.collectionVariables.get(name); }",
                  "function setVar(name, value) {",
                  "  if (value === undefined || value === null || value === '') return;",
                  "  try { pm.environment.set(name, String(value)); } catch (e) {}",
                  "  pm.collectionVariables.set(name, String(value));",
                  "}",
                  "function setIfMissing(name, value) { if (!getVar(name)) setVar(name, value); }",
                  "function uuidv4() {",
                  "  return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {",
                  "    const r = Math.random() * 16 | 0;",
                  "    const v = c === 'x' ? r : (r & 0x3 | 0x8);",
                  "    return v.toString(16);",
                  "  });",
                  "}",
                  "function todayIso() { return new Date().toISOString().slice(0, 10); }",
                  "const materiaAlias = getVar('materia_ofertada_id') || getVar('ms2_materia_ofertada_id');",
                  "if (materiaAlias) setVar('materia_id', materiaAlias);",
                  "if (!getVar('materia_id')) setVar('materia_id', uuidv4());",
                  "if (!getVar('alumno_id')) setVar('alumno_id', uuidv4());",
                  "setVar('actividad_fecha', todayIso());",
                  "['ponderacion_examen_id','ponderacion_tareas_id','ponderacion_proyecto_id','ponderacion_asistencia_id','actividad_id','calificacion_id'].forEach(function (name) {",
                  "  try { pm.environment.unset(name); } catch (e) {}",
                  "  pm.collectionVariables.unset(name);",
                  "});"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 2xx', function () { pm.expect(pm.response.code).to.be.within(200, 299); });",
                  "let json = {};",
                  "try { json = pm.response.json(); } catch (e) { json = {}; }",
                  "const data = json.data || json;",
                  "function getVar(name) { return pm.environment.get(name) || pm.collectionVariables.get(name); }",
                  "function setVar(name, value) {",
                  "  if (value === undefined || value === null || value === '') return;",
                  "  try { pm.environment.set(name, String(value)); } catch (e) {}",
                  "  pm.collectionVariables.set(name, String(value));",
                  "}",
                  "setVar('materia_id', data.materia_id);",
                  "const criterios = data.criterios || data.ponderaciones || [];",
                  "criterios.forEach(function (c) {",
                  "  const name = (c.nombre || '').toLowerCase();",
                  "  const id = c.id || c.ponderacion_id;",
                  "  if (name.includes('examen') || name.includes('exámen')) setVar('ponderacion_examen_id', id);",
                  "  if (name.includes('tarea')) setVar('ponderacion_tareas_id', id);",
                  "  if (name.includes('proyecto')) setVar('ponderacion_proyecto_id', id);",
                  "  if (name.includes('asistencia')) setVar('ponderacion_asistencia_id', id);",
                  "});",
                  "if (criterios.length && !getVar('ponderacion_examen_id')) setVar('ponderacion_examen_id', criterios[0].id || criterios[0].ponderacion_id);"
                ]
              }
            }
          ]
        },
