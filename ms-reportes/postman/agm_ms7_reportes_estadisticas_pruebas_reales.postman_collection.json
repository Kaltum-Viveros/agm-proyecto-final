    "name": "AGM - MS-7 Reportes y Estadísticas - Pruebas reales",
    "description": "Colección ajustada para MS-7 Reportes & Estadísticas. Usa ms_reportes_base_url, headers Authorization: Bearer {{access_token}}, variables compartidas con MS-2/MS-3/MS-4/MS-5 y captura metadatos de descarga/estadísticas para encadenar pruebas.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "function getVar(name) {",
          "  return pm.environment.get(name) || pm.collectionVariables.get(name);",
          "}",
          "",
          "function setVar(name, value) {",
          "  if (value === undefined || value === null || value === '') return;",
          "  try { pm.environment.set(name, String(value)); } catch (e) {}",
          "  pm.collectionVariables.set(name, String(value));",
          "}",
          "",
          "function setIfMissing(name, value) {",
          "  if (!getVar(name)) setVar(name, value);",
          "}",
          "",
          "setIfMissing('ms_reportes_base_url', 'http://localhost:8007');",
          "if (!getVar('access_token') && getVar('admin_access_token')) setVar('access_token', getVar('admin_access_token'));",
          "if (!getVar('materia_id') && getVar('materia_ofertada_id')) setVar('materia_id', getVar('materia_ofertada_id'));",
          "if (!getVar('materia_id') && getVar('ms2_materia_ofertada_id')) setVar('materia_id', getVar('ms2_materia_ofertada_id'));",
          "setIfMissing('reporte_formato_pdf', 'pdf');",
          "setIfMissing('reporte_formato_xlsx', 'xlsx');",
          "if (!getVar('docente_id')) console.warn('Falta docente_id. Ejecútalo después de MS-3 o llena la variable en el environment.');",
          "if (!getVar('alumno_id')) console.warn('Falta alumno_id. Ejecútalo después de MS-3 o llena la variable en el environment.');",
          "if (!getVar('materia_id')) console.warn('Falta materia_id. Ejecútalo después de MS-2/MS-3/MS-4 o llena la variable en el environment.');"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test('Status HTTP esperado', function () {",
          "  pm.expect(pm.response.code).to.be.oneOf([200, 201, 202, 204]);",
          "});"
        ]
      }
    }
  ],
