    {
      "name": "02 - Estadísticas",
      "description": "Consultas de estadísticas por docente y por alumno.",
      "item": [
        {
          "name": "Estadísticas docente",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text",
                "description": "JWT Bearer token generado por MS-1 Auth"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{ms_reportes_base_url}}/api/v1/estadisticas/docente/{{docente_id}}",
            "description": "Consulta estadísticas históricas/agregadas de un docente."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Estadísticas docente responden 200', function () { pm.response.to.have.status(200); });",
                  "let json = {};",
                  "try { json = pm.response.json(); } catch (e) { json = {}; }",
                  "const data = json.data || json;",
                  "function setVar(name, value) {",
                  "  if (value === undefined || value === null || value === '') return;",
                  "  try { pm.environment.set(name, String(value)); } catch (e) {}",
                  "  pm.collectionVariables.set(name, String(value));",
                  "}",
                  "setVar('estadisticas_docente_total_materias', data.total_materias || data.materias_total || data.materias);",
                  "setVar('estadisticas_docente_total_alumnos', data.total_alumnos || data.alumnos_total || data.alumnos);",
                  "setVar('estadisticas_docente_promedio_general', data.promedio_general || data.promedio || data.promedio_calificaciones);",
                  "setVar('estadisticas_docente_promedio_asistencia', data.promedio_asistencia || data.porcentaje_asistencia || data.asistencia_promedio);"
                ]
              }
            }
          ]
        },
        {
          "name": "Estadísticas alumno",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text",
                "description": "JWT Bearer token generado por MS-1 Auth"
