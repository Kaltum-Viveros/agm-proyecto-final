                  "setVar('estadisticas_alumno_promedio_general', data.promedio_general || data.promedio || data.promedio_calificaciones);",
                  "setVar('estadisticas_alumno_promedio_asistencia', data.promedio_asistencia || data.porcentaje_asistencia || data.asistencia_promedio);",
                  "setVar('estadisticas_alumno_total_asistencias', data.total_asistencias || data.asistencias_total || data.asistencias);"
                ]
