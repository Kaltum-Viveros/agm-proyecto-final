# ─── Identidad del servicio ───────────────────────────────────────────────────
SERVICE_NAME=ms-reportes
ENVIRONMENT=development
DEBUG=true

# ─── REST ─────────────────────────────────────────────────────────────────────
REST_HOST=0.0.0.0
REST_PORT=8007

# ─── gRPC ─────────────────────────────────────────────────────────────────────
GRPC_HOST=0.0.0.0
GRPC_PORT=50057

# ─── Base de datos ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres_password@reportes_db:5432/agm_reportes_db

# ─── API ──────────────────────────────────────────────────────────────────────
API_V1_PREFIX=/api/v1

# ─── Clientes gRPC de otros microservicios ────────────────────────────────────
AUTH_GRPC_HOST=ms-auth
AUTH_GRPC_PORT=50051

MATERIAS_GRPC_HOST=ms-periodos-materias
MATERIAS_GRPC_PORT=50052

ALUMNOS_GRPC_HOST=ms-docentes-alumnos
ALUMNOS_GRPC_PORT=50053

CALIFICACIONES_GRPC_HOST=ms-calificaciones
CALIFICACIONES_GRPC_PORT=50054

ASISTENCIAS_GRPC_HOST=ms-asistencias
ASISTENCIAS_GRPC_PORT=50055
