APP_NAME=MS Auth & Users
APP_ENV=development
DEBUG=true

REST_HOST=0.0.0.0
REST_PORT=8001

GRPC_HOST=0.0.0.0
GRPC_PORT=50051

CORS_ORIGINS=http://localhost:4200,http://localhost:3000

DATABASE_URL=postgresql://agm_auth_user:agm_auth_password@localhost:5432/agm_auth_db

JWT_SECRET_KEY=change-this-secret-key-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=15

SEED_ADMIN_NAME=Administrador AGM
SEED_ADMIN_EMAIL=admin@agm.com
SEED_ADMIN_PASSWORD=change-this-local-password