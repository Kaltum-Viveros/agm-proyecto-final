{
  "info": {
    "_postman_id": "ccd9cd88-789c-45a7-b0d5-e946e772a803",
    "name": "AGM - MS-5 Asistencias QR - Pruebas reales",
    "description": "Colección ajustada para MS-5 Asistencias QR. Mantiene el flujo de la colección base: health, inicio/detalle/cierre de sesión, generación de QR por alumno, registro de asistencia por docente, historial, asistencias del día y estadísticas. Usa variables del environment AGM y guarda automáticamente id_sesion/token_cifrado/resultados para encadenar pruebas.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "function getVar(name) {",
          "  return pm.environment.get(name) || pm.collectionVariables.get(name);",
          "}",
          "",
          "function setVar(name, value) {",
          "  if (value === undefined || value === null || value === '') return;",
          "  try { pm.environment.set(name, String(value)); } catch (e) {}",
          "  pm.collectionVariables.set(name, String(value));",
          "}",
          "",
          "function setIfMissing(name, value) {",
          "  if (!getVar(name)) setVar(name, value);",
          "}",
          "",
          "function isPlaceholder(value) {",
          "  if (!value) return true;",
          "  return String(value).includes('INGRESA') || String(value).includes('AQUI') || String(value).includes('Pega_aqui');",
          "}",
          "",
          "setIfMissing('ms_asistencias_base_url', 'http://localhost:8005');",
          "",
          "// Compatibilidad con la colección original del MS-5.",
          "if (!getVar('docente_access_token') && !isPlaceholder(getVar('bearerTokenDocente'))) {",
          "  setVar('docente_access_token', getVar('bearerTokenDocente'));",
          "}",
          "if (!getVar('alumno_access_token') && !isPlaceholder(getVar('bearerTokenAlumno'))) {",
          "  setVar('alumno_access_token', getVar('bearerTokenAlumno'));",
          "}",
          "",
          "// Fallback práctico: si estás autenticado como docente en access_token, úsalo para endpoints de docente.",
          "if (!getVar('docente_access_token') && getVar('access_token')) {",
          "  setVar('docente_access_token', getVar('access_token'));",
          "}",
          "",
          "// Si MS-2/MS-3 ya dejaron una materia en el environment, úsala como id_materia.",
          "if (!getVar('id_materia') && getVar('materia_id')) {",
          "  setVar('id_materia', getVar('materia_id'));",
          "}",
          "if (!getVar('id_materia') && getVar('materia_ofertada_id')) {",
          "  setVar('id_materia', getVar('materia_ofertada_id'));",
          "}"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test('Status HTTP esperado', function () {",
          "  pm.expect(pm.response.code).to.be.oneOf([200, 201, 202, 204]);",
          "});"
        ]
      }
    }
  ],
