            "description": "Genera el payload/token cifrado del QR dinámico del alumno. Requiere token de ALUMNO.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id_sesion\": \"{{id_sesion}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('QR generado', function () { pm.expect(pm.response.code).to.be.oneOf([200, 201, 202]); });",
                  "let json = {};",
                  "try { json = pm.response.json(); } catch (e) { json = {}; }",
                  "const data = json.data || json;",
                  "function setVar(name, value) {",
                  "  if (value === undefined || value === null || value === '') return;",
                  "  try { pm.environment.set(name, String(value)); } catch (e) {}",
                  "  pm.collectionVariables.set(name, String(value));",
                  "}",
                  "const token = data.token_cifrado || data.qr_token || data.token || data.codigo_qr || data.qr || data.payload;",
                  "setVar('token_cifrado', token);",
                  "setVar('qr_token_cifrado', token);"
                ]
              }
            }
          ]
        }
      ]
    },
