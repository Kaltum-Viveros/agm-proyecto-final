    {
      "name": "00 - General",
      "item": [
        {
          "name": "Health Check / Estado de Salud",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{ms_asistencias_base_url}}/",
            "description": "Verifica el estado operacional básico y disponibilidad del microservicio."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Health responde 200', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "01 - Sesiones",
      "description": "Flujo docente: abrir una sesión de asistencia y consultar sus detalles. El cierre queda al final para no cortar el flujo QR.",
      "item": [
        {
          "name": "Iniciar sesión de asistencia",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{docente_access_token}}",
                "type": "text",
                "description": "JWT Bearer token de usuario DOCENTE generado por MS-1 Auth"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{ms_asistencias_base_url}}/sesiones/iniciar",
            "description": "Abre una nueva sesión de asistencia activa para una materia específica. Requiere token de DOCENTE.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id_materia\": \"{{id_materia}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Sesión iniciada', function () { pm.expect(pm.response.code).to.be.oneOf([200, 201, 202]); });",
                  "let json = {};",
                  "try { json = pm.response.json(); } catch (e) { json = {}; }",
                  "const data = json.data || json;",
                  "function setVar(name, value) {",
                  "  if (value === undefined || value === null || value === '') return;",
                  "  try { pm.environment.set(name, String(value)); } catch (e) {}",
                  "  pm.collectionVariables.set(name, String(value));",
                  "}",
                  "setVar('id_sesion', data.id_sesion || data.sesion_id || data.id || data.session_id);",
                  "setVar('sesion_id', data.id_sesion || data.sesion_id || data.id || data.session_id);",
                  "setVar('id_materia', data.id_materia || data.materia_id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Obtener detalles de sesión",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{docente_access_token}}",
                "type": "text",
                "description": "JWT Bearer token de usuario DOCENTE generado por MS-1 Auth"
              }
            ],
            "url": "{{ms_asistencias_base_url}}/sesiones/{{id_sesion}}",
            "description": "Retorna la información y metadatos de la sesión de asistencia."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status HTTP esperado', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201, 202, 204]);",
                  "});",
                  "let json = {};",
                  "try { json = pm.response.json(); } catch (e) { json = {}; }",
                  "const data = json.data || json;",
                  "function setVar(name, value) {",
                  "  if (value === undefined || value === null || value === '') return;",
                  "  try { pm.environment.set(name, String(value)); } catch (e) {}",
                  "  pm.collectionVariables.set(name, String(value));",
                  "}",
                  "setVar('id_sesion', data.id_sesion || data.sesion_id || data.id || data.session_id);",
                  "setVar('sesion_estado', data.estado || data.status);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
