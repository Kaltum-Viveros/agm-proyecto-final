                  "}",
                  "let items = [];",
                  "if (Array.isArray(data)) items = data;",
                  "else if (Array.isArray(data.items)) items = data.items;",
                  "else if (Array.isArray(data.asistencias)) items = data.asistencias;",
                  "else if (Array.isArray(data.registros)) items = data.registros;",
                  "setVar('asistencia_historial_total', items.length);"
                ]
              }
            }
          ]
