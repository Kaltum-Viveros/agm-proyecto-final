    {
      "name": "03 - Importación PDF de programación académica",
      "item": [
        {
          "name": "03.1 Importar programación académica PDF",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{ms_periodos_materias_base_url}}/importaciones/programacion-academica",
            "description": "Adjunta manualmente el PDF oficial de programación académica en el campo archivo. El documento base lo define como POST /periodos/importar; en esta implementación el endpoint Swagger es /importaciones/programacion-academica. periodo_id y plan_estudio_id quedan ligados a variables.",
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "periodo_id",
                  "value": "{{periodo_id}}",
                  "type": "text"
                },
                {
                  "key": "plan_estudio_id",
                  "value": "{{plan_estudio_id}}",
                  "type": "text"
                },
                {
                  "key": "archivo",
                  "type": "file",
                  "src": []
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let json = {};",
                  "try { json = pm.response.json(); } catch (e) { json = {}; }",
                  "const data = json.data || json;",
                  "function setVar(name, value) {",
                  "  if (value === undefined || value === null || value === '') return;",
                  "  try { pm.environment.set(name, String(value)); } catch (e) {}",
                  "  pm.collectionVariables.set(name, String(value));",
                  "}",
                  "function getVar(name) { return pm.environment.get(name) || pm.collectionVariables.get(name); }",
                  "function setIfMissing(name, value) { if (!getVar(name)) setVar(name, value); }",
                  "pm.test('Importación procesó filas del PDF', function () {",
                  "  pm.expect(data).to.have.property('filas_extraidas');",
                  "  pm.expect(data.filas_extraidas).to.be.above(0);",
                  "});"
                ]
              }
            }
          ]
        }
      ],
      "description": "Flujo principal del MS-2: cargar el PDF oficial de programación académica para que el servicio extraiga NRC, materia, sección, docente y horario."
    },
