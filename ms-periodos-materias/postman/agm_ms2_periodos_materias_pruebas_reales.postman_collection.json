      "name": "00 - Health",
      "item": [
        {
          "name": "00.1 Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{ms_periodos_materias_base_url}}/health",
            "description": "Verifica que el microservicio MS-2 esté levantado.",
            "auth": {
              "type": "noauth"
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "function uuidv4() {",
                  "  return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {",
                  "    const r = Math.random() * 16 | 0;",
                  "    const v = c === 'x' ? r : (r & 0x3 | 0x8);",
                  "    return v.toString(16);",
                  "  });",
                  "}",
                  "",
                  "function setVar(name, value) {",
                  "  if (value === undefined || value === null || value === '') return;",
                  "  try { pm.environment.set(name, String(value)); } catch (e) {}",
                  "  pm.collectionVariables.set(name, String(value));",
                  "}",
                  "",
                  "const suffix = Date.now().toString().slice(-8);",
                  "const nrc = String(10000 + Math.floor(Math.random() * 89999));",
                  "",
                  "setVar('ms2_run_suffix', suffix);",
                  "setVar('periodo_nombre', `Periodo Postman ${suffix}`);",
                  "setVar('periodo_nombre_actualizado', `Periodo Postman ${suffix} Actualizado`);",
                  "setVar('plan_estudio_nombre', `Plan AGM Postman ${suffix}`);",
                  "setVar('plan_estudio_nombre_actualizado', `Plan AGM Postman ${suffix} Actualizado`);",
                  "setVar('materia_clave', `SW${suffix}`.slice(0, 30));",
                  "setVar('materia_clave_actualizada', `SW${suffix}A`.slice(0, 30));",
                  "setVar('materia_nombre', `Servicios Web Postman ${suffix}`);",
                  "setVar('materia_nombre_actualizado', `Servicios Web Postman ${suffix} Actualizada`);",
                  "setVar('materia_nrc', nrc);",
                  "",
                  "// Limpia ids para que el flujo tome los recursos recién creados.",
                  "['periodo_id','periodo_activo_id','plan_estudio_id','materia_catalogo_id','materia_plan_estudio_id','materia_ofertada_id','materia_horario_id'].forEach(function (name) {",
                  "  try { pm.environment.unset(name); } catch (e) {}",
                  "  pm.collectionVariables.unset(name);",
                  "});",
                  "",
                  "if (!(pm.environment.get('docente_id') || pm.collectionVariables.get('docente_id'))) {",
                  "  setVar('docente_id', uuidv4());",
                  "}"
                ]
              }
            }
          ]
        },
