{
  "info": {
    "_postman_id": "3f3e1d84-2c72-44c0-bb05-4c0dd984790d",
    "name": "AGM - MS-2 Periodos & Materias - Pruebas reales",
    "description": "Colección reformulada para revisión final de MS-2 con base en el documento del proyecto. Prioriza solo los flujos exigidos o directamente justificados por el documento: health, gestión de periodos, preparación mínima de plan de estudio cuando la implementación lo requiere, importación PDF de programación académica y consultas de materias. Se eliminaron de la ruta principal los CRUD internos de catálogo, relación materia-plan, materias ofertadas y horarios porque el documento pide que la programación académica se registre automáticamente desde el PDF.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "function uuidv4() {",
          "  return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {",
          "    const r = Math.random() * 16 | 0;",
          "    const v = c === 'x' ? r : (r & 0x3 | 0x8);",
          "    return v.toString(16);",
          "  });",
          "}",
          "",
          "function getVar(name) {",
          "  return pm.environment.get(name) || pm.collectionVariables.get(name);",
          "}",
          "",
          "function setVar(name, value) {",
          "  if (value === undefined || value === null || value === '') return;",
          "  try { pm.environment.set(name, String(value)); } catch (e) {}",
          "  pm.collectionVariables.set(name, String(value));",
          "}",
          "",
          "function setIfMissing(name, value) {",
          "  if (!getVar(name)) setVar(name, value);",
          "}",
          "",
          "setIfMissing('ms_periodos_materias_base_url', 'http://localhost:8002/api/v1');",
          "setIfMissing('ms2_page', '1');",
          "setIfMissing('ms2_limit', '10');",
          "setIfMissing('periodo_fecha_inicio', '2030-01-01');",
          "setIfMissing('periodo_fecha_fin', '2030-06-30');",
          "setIfMissing('periodo_fecha_fin_actualizada', '2030-07-15');",
          "setIfMissing('docente_id', uuidv4());",
          "setIfMissing('docente_nombre', 'Docente externo MS-3');"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test('Status HTTP esperado', function () {",
          "  pm.expect(pm.response.code).to.be.oneOf([200, 201, 202, 204]);",
          "});",
          "",
          "let json = {};",
          "try {",
          "  json = pm.response.json();",
          "} catch (e) {",
          "  json = {};",
          "}",
          "",
          "if (Object.prototype.hasOwnProperty.call(json, 'success')) {",
          "  pm.test('Respuesta success=true', function () {",
          "    pm.expect(json.success).to.eql(true);",
          "  });",
          "}"
        ]
      }
    }
  ],
