  "item": [
    {
      "name": "00 - Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{ms_notificaciones_base_url}}/",
            "description": "Verifica que MS-6 esté levantado. No requiere Authorization."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Health responde 200', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "01 - Correos transaccionales",
      "description": "Smoke tests REST del MS-6. Todos usan header Authorization: Bearer {{access_token}}.",
      "item": [
        {
          "name": "Enviar bienvenida",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{ms_notificaciones_base_url}}/api/v1/notificaciones/bienvenida",
            "description": "Envía correo de bienvenida/clave temporal para un alumno. El servicio obtiene datos del alumno vía gRPC contra MS-3.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"alumno_id\": \"{{alumno_id}}\",\n  \"materia_id\": \"{{materia_id}}\",\n  \"password_temporal\": \"{{password_temporal}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status HTTP esperado', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201, 202, 204]);",
                  "});",
                  "let json = {};",
                  "try { json = pm.response.json(); } catch (e) { json = {}; }",
                  "const data = json.data || json;",
                  "function setVar(name, value) {",
                  "  if (value === undefined || value === null || value === '') return;",
                  "  try { pm.environment.set(name, String(value)); } catch (e) {}",
                  "  pm.collectionVariables.set(name, String(value));",
                  "}",
                  "setVar('notificacion_id', data.id || data.notificacion_id);",
                  "setVar('notificacion_tipo', data.tipo);",
                  "setVar('notificacion_estado', data.estado);",
                  "setVar('notificacion_email', data.email);",
                  "setVar('bienvenida_notificacion_id', data.id || data.notificacion_id);"
                ]
              }
            }
          ]
        },
