{
  "info": {
    "_postman_id": "8856782e-a8c3-44f8-9764-53e246d79508",
    "name": "AGM - MS-6 Notificaciones - Pruebas reales",
    "description": "Colección mínima-realista para MS-6 Notificaciones. Incluye únicamente health y los cuatro endpoints REST externos que el documento base marca para este microservicio: bienvenida, baja, cierre de materia y reset-password. Las integraciones gRPC se prueban indirectamente desde otros microservicios; aquí se valida la superficie REST para smoke test, evidencia de envío de correos y documentación Postman. El token se envía como header Authorization: Bearer {{access_token}}.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "function getVar(name) { return pm.environment.get(name) || pm.collectionVariables.get(name); }",
          "function setVar(name, value) {",
          "  if (value === undefined || value === null || value === '') return;",
          "  try { pm.environment.set(name, String(value)); } catch (e) {}",
          "  pm.collectionVariables.set(name, String(value));",
          "}",
          "function setIfMissing(name, value) { if (!getVar(name)) setVar(name, value); }",
          "function uuidv4() {",
          "  return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {",
          "    const r = Math.random() * 16 | 0;",
          "    const v = c === 'x' ? r : (r & 0x3 | 0x8);",
          "    return v.toString(16);",
          "  });",
          "}",
          "setIfMissing('ms_notificaciones_base_url', 'http://localhost:8005');",
          "if (!getVar('access_token') && getVar('admin_access_token')) setVar('access_token', getVar('admin_access_token'));",
          "if (!getVar('materia_id') && getVar('materia_ofertada_id')) setVar('materia_id', getVar('materia_ofertada_id'));",
          "setIfMissing('alumno_id', uuidv4());",
          "setIfMissing('docente_id', uuidv4());",
          "setIfMissing('materia_id', uuidv4());",
          "setIfMissing('password_temporal', 'Temp12345!');",
          "if (!getVar('usuario_id') && getVar('current_user_id')) setVar('usuario_id', getVar('current_user_id'));",
          "if (!getVar('usuario_id') && getVar('alumno_user_id')) setVar('usuario_id', getVar('alumno_user_id'));",
          "setIfMissing('usuario_id', uuidv4());",
          "if (!getVar('reset_email') && getVar('auth_email')) setVar('reset_email', getVar('auth_email'));",
          "if (!getVar('reset_email') && getVar('password_reset_email')) setVar('reset_email', getVar('password_reset_email'));",
          "setIfMissing('reset_email', 'usuario.prueba@correo.buap.mx');",
          "setIfMissing('reset_token', 'reset-demo-' + Date.now());"
        ]
      }
    }
  ],
