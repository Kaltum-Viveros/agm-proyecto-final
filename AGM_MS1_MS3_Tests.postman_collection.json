{
  "info": {
    "name": "AGM - MS1 (Auth) & MS3 (Docentes/Alumnos)",
    "_postman_id": "agm-ms1-ms3-grpc-tests",
    "description": "Colección de pruebas para el flujo completo de autenticación (MS-1, puerto 8001) y gestión de docentes/alumnos (MS-3, puerto 8003). Cubre casos válidos y de error, incluyendo la comunicación gRPC interna entre ambos microservicios.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "MS1_URL",         "value": "http://localhost:8001", "type": "string" },
    { "key": "MS3_URL",         "value": "http://localhost:8003", "type": "string" },
    { "key": "access_token",    "value": "", "type": "string" },
    { "key": "refresh_token",   "value": "", "type": "string" },
    { "key": "docente_id",      "value": "", "type": "string" },
    { "key": "alumno_id",       "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "🔐 MS-1 Auth — Casos Válidos",
      "item": [
        {
          "name": "[OK] Login exitoso",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Contiene access_token', () => pm.expect(body.data.access_token).to.be.a('string'));",
                  "pm.collectionVariables.set('access_token', body.data.access_token);",
                  "pm.collectionVariables.set('refresh_token', body.data.refresh_token);",
                  "console.log('✅ Tokens guardados en variables de colección.');"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@agm.com\",\n  \"contrasena\": \"Admin1234!\"\n}"
            },
            "url": { "raw": "{{MS1_URL}}/auth/login", "host": ["{{MS1_URL}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "[OK] GET /auth/me — Perfil del usuario autenticado",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Contiene email', () => pm.expect(body.data.email).to.be.a('string'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{MS1_URL}}/auth/me", "host": ["{{MS1_URL}}"], "path": ["auth", "me"] }
          }
        },
        {
          "name": "[OK] Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Nuevo access_token recibido', () => pm.expect(body.data.access_token).to.be.a('string'));",
                  "pm.collectionVariables.set('access_token', body.data.access_token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            },
            "url": { "raw": "{{MS1_URL}}/auth/refresh-token", "host": ["{{MS1_URL}}"], "path": ["auth", "refresh-token"] }
          }
        },
        {
          "name": "[OK] Health Check MS-1",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{MS1_URL}}/health", "host": ["{{MS1_URL}}"], "path": ["health"] }
          }
        }
      ]
    },
    {
      "name": "❌ MS-1 Auth — Casos de Error",
      "item": [
        {
          "name": "[ERROR] Login — Credenciales incorrectas",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));",
                  "const body = pm.response.json();",
                  "pm.test('Error code AUTH_INVALID_CREDENTIALS', () => pm.expect(body.error_code).to.eql('AUTH_INVALID_CREDENTIALS'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@agm.com\",\n  \"contrasena\": \"contrasenaMal123\"\n}"
            },
            "url": { "raw": "{{MS1_URL}}/auth/login", "host": ["{{MS1_URL}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "[ERROR] Login — Email no registrado",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"noexiste@agm.com\",\n  \"contrasena\": \"cualquierCosa1!\"\n}"
            },
            "url": { "raw": "{{MS1_URL}}/auth/login", "host": ["{{MS1_URL}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "[ERROR] GET /auth/me — Sin token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401 o 403', () => pm.expect(pm.response.code).to.be.oneOf([401, 403]));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{MS1_URL}}/auth/me", "host": ["{{MS1_URL}}"], "path": ["auth", "me"] }
          }
        },
        {
          "name": "[ERROR] GET /auth/me — Token inválido (falso)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));",
                  "const body = pm.response.json();",
                  "pm.test('Error code de token invalido', () => pm.expect(body.error_code).to.include('INVALID'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer token.falso.aqui" }],
            "url": { "raw": "{{MS1_URL}}/auth/me", "host": ["{{MS1_URL}}"], "path": ["auth", "me"] }
          }
        },
        {
          "name": "[ERROR] Refresh Token — Token inválido",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));",
                  "const body = pm.response.json();",
                  "pm.test('Error code AUTH_INVALID_REFRESH_TOKEN', () => pm.expect(body.error_code).to.eql('AUTH_INVALID_REFRESH_TOKEN'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"refresh.token.falso.xyz\"\n}"
            },
            "url": { "raw": "{{MS1_URL}}/auth/refresh-token", "host": ["{{MS1_URL}}"], "path": ["auth", "refresh-token"] }
          }
        }
      ]
    },
